# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Local configuration files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Log files and databases
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
*.sqlite

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Archives and build artifacts
*.zip
*.tar.gz
*.rar
build/
dist/

# Dynamic application state
portfolio_state.json

# ─── V2 RUNTIME STATE (don't track — regenerates every retrain/monitor cycle) ───
# Training data: ~12 MB per symbol, grows daily via live auto-append.
# The bot bootstraps these from disk at startup; if cloning fresh, regenerate
# by attaching the NT8 strategies to each chart and waiting for live bars.
data/*.csv

# Auto-rollback safety backups (~3-6 MB each, retrained twice a day)
models_baseline_*/
models/*.json.backup

# Per-cycle runtime state — monitor + alerts + retrain logs + per-symbol reports
models/active_alerts.json
models/daily_monitor_history.json
models/monitor_logs/
models/retrain_logs/
models/reports/
models/simulation_*.json
models/backtest_gate*.json
models/bt_gate*.out
models/paper_trades.json
models/exit_overrides.legacy_backup.json
models/highwr_train_log.txt
# User UI state — flips whenever user clicks an Aggressiveness preset card
models/aggressiveness_profile.json

# Secrets — telegram/tastytrade/openai/alpaca tokens. NEVER commit.
models/credentials.json

# Runtime startup capture (stdout/stderr of run_bot.bat)
startup_out.txt
startup_err.txt

# Historical server stderr dumps in logs/ — noise, not source
logs/*.err

# Compiled Python bytecode
scripts/__pycache__/
__pycache__/

# NT8 backup files generated during hot-fixes
NT8_Bridge/*.bak*
